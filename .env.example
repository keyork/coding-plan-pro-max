# Upstream API keys. Comma-separated for multiple keys.
# When one key hits quota, the proxy auto-rotates to the next.
API_KEY=key1,key2

# Upstream API base URL (required, must be a valid URL).
UPSTREAM_BASE_URL=https://example.com/api/v4

# Port to listen on (default: 3000)
PORT=3000

# Cooldown in ms before retrying an exhausted key (default: 18000000 = 5h)
# COOLDOWN_MS=18000000
